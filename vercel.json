{
  "version": 2,
  "builds": [
    {
      "src": "app/server/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "app/client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "app/server/api/index.py"
    },
    {
      "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|svg|woff|woff2|ttf|eot|gif|webp|json))",
      "dest": "app/client/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app/client/index.html"
    }
  ]
}
