{
  "version": 2,
  "installCommand": "cd app/client && npm install",
  "buildCommand": "cd app/client && npm run build",
  "outputDirectory": "app/client/dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "app/server/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api" }
  ]
}
